# Groq cloud API — get free key at https://console.groq.com
# When set, Groq is used automatically instead of Ollama
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Local Ollama (fallback when GROQ_API_KEY is not set)
OLLAMA_HOST=http://localhost:11434
MAESTRO_MODEL=mistral:latest
MAESTRO_TIMEOUT=120
